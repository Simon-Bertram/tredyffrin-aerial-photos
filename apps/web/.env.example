# Canonical public URL (Astro env schema). For production builds and deploys,
# set this to the real site URL—not http://localhost:3000.
PUBLIC_SERVER_URL=https://example.com

# Sanity Content Lake (required for locations)
PUBLIC_SANITY_PROJECT_ID=
PUBLIC_SANITY_DATASET=production

# Only if the dataset is private (server-side reads)
# SANITY_API_READ_TOKEN=
