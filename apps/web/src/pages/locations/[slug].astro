---
import Layout from "../../layouts/Layout.astro";
import LocationDetail from "@/components/location/location-detail.astro";
import LocationNotFound from "@/components/location/location-not-found.astro";
import { buildLocationPageLayoutMeta } from "@/lib/location-page-seo";
import { getSanityLocationRecordBySlug } from "@/lib/sanity-location-repository";
import { getSiteOrigin } from "@/lib/site-url";

const { slug } = Astro.params;
const location = slug ? await getSanityLocationRecordBySlug(slug) : undefined;

if (!location) {
  Astro.response.status = 404;
}

const siteOrigin = getSiteOrigin();
const { pageTitle, pageDescription, previewSrc, previewAlt, jsonLd } =
  buildLocationPageLayoutMeta(location, siteOrigin);
---

<Layout
  title={pageTitle}
  description={pageDescription}
  image={previewSrc}
  imageAlt={previewAlt}
  jsonLd={jsonLd ? [jsonLd] : undefined}
  robots={location ? undefined : "noindex, nofollow"}
>
  <main
    id="main-content"
    class="container mx-auto max-w-7xl space-y-6 px-4 py-6"
  >
    {location ? (
      <LocationDetail
        location={location}
        highlightPhotoId={Astro.url.searchParams.get("photo")}
      />
    ) : (
      <LocationNotFound />
    )}
  </main>
</Layout>
