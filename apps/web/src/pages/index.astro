---
import Layout from "../layouts/Layout.astro";
import { TredyffrinMap } from "../components/map/tredyffrinMap";
import { SelectedPhotos } from "../components/selected-photos";
import { fetchLocationsForMap } from "@/lib/sanity-location-repository";
import { getSiteOrigin } from "@/lib/site-url";

const locations = await fetchLocationsForMap();

const photoCount = locations.reduce(
  (total, location) => total + location.photos.length,
  0,
);

const updated = new Date().toLocaleDateString("en-US", {
  month: "long",
  year: "numeric",
});

const homeTitle = "Tredyffrin, from above — The Aerial Archive";
const homeDescription =
  "A collection of aerial photographs documenting the landscape of Tredyffrin Township, Pennsylvania.";
const firstPreview = locations[0]?.photos[0];
const siteOrigin = getSiteOrigin();
const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: homeTitle,
    url: `${siteOrigin}/`,
    description: homeDescription,
  },
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    name: "Tredyffrin Easttown Historical Society",
  },
];
---

<Layout
  title={homeTitle}
  description={homeDescription}
  image={firstPreview?.src}
  imageAlt={firstPreview?.alt}
  jsonLd={jsonLd}
>
  <main id="main-content" class="relative">
    {/* ------------------------------------------------------------------ */}
    {/* Hero / masthead                                                     */}
    {/* ------------------------------------------------------------------ */}
    <section
      class="relative mx-auto max-w-7xl px-6 pt-14 pb-14 md:px-10 md:pt-24 md:pb-20"
    >
      <div class="grid gap-12 md:grid-cols-12 md:gap-16">
        <h1
          class="font-display font-light leading-[1.02] tracking-[-0.02em] text-[clamp(2.5rem,6vw,3.5rem)] md:col-span-9 md:col-start-2"
        >
          Tredyffrin,
          <span class="text-primary italic">from above.</span>
        </h1>

        <p
          class="text-base leading-[1.75] text-on-surface-variant md:col-span-7 md:col-start-6 md:text-[1.05rem]"
        >
          A collection of aerial photographs documenting the landscape and
          history of Tredyffrin Township, Pennsylvania
        </p>
      </div>
    </section>

    {/* ------------------------------------------------------------------ */}
    {/* § I. The Map                                                      */}
    {/* ------------------------------------------------------------------ */}
    <section class="relative mx-auto max-w-7xl px-6 pb-16 md:px-10 md:pb-24">
      <div
        class="mb-8 flex flex-col gap-6 md:mb-12 md:flex-row md:items-end md:justify-between"
      >
        <h2
          class="font-display text-[clamp(1.75rem,4vw,2.25rem)] font-light tracking-[-0.01em] text-foreground md:max-w-md"
        >
          The <span class="italic text-primary">map.</span>
        </h2>
        <p
          class="max-w-sm font-display italic leading-snug text-on-surface-variant md:text-right"
        >
          &ldquo;Activate a marker to open that location&rsquo;s photographs and
          details. When using a mouse or trackpad, pointing at a marker may show
          a preview first. The same locations appear in{' '}
          <a
            href="#selected-photographs"
            class="text-primary underline-offset-4 hover:underline not-italic"
            >Selected photographs</a
          >
          below.&rdquo;
        </p>
      </div>

      <div
        class="bg-surface-container-low p-3 shadow-[0_32px_48px_color-mix(in_srgb,var(--on-surface)_5%,transparent)] md:p-4"
      >
        {
          locations.length > 0 ? (
            <div class="relative min-h-[320px] h-[75vh]">
              <TredyffrinMap client:visible locations={locations}>
                <div slot="fallback" class="absolute inset-0">
                  <div class="bg-surface-container h-full w-full animate-pulse">
                    <div class="flex h-full items-center justify-center">
                      <div class="flex gap-1">
                        <span class="bg-on-surface-variant/30 size-1.5 rounded-full" />
                        <span class="bg-on-surface-variant/30 size-1.5 rounded-full" />
                        <span class="bg-on-surface-variant/30 size-1.5 rounded-full" />
                      </div>
                    </div>
                  </div>
                </div>
              </TredyffrinMap>
            </div>
          ) : (
            <p class="p-16 text-center font-display italic text-on-surface-variant">
              The atlas is unfurled, yet bears no markings. Add locations in
              Sanity Studio to begin.
            </p>
          )
        }
      </div>
      <dl
        class="mt-12 flex flex-wrap items-center gap-2 md:mt-20"
        aria-label="Collection at a glance"
      >
        <dt class="sr-only">Locations</dt>
        <dd
          class="bg-secondary-fixed text-on-secondary-fixed px-3 py-1.5 font-sans text-[11px] uppercase tracking-[0.16em]"
        >
          {locations.length} Locations
        </dd>
        <dt class="sr-only">Photographs</dt>
        <dd
          class="bg-secondary-fixed text-on-secondary-fixed px-3 py-1.5 font-sans text-[11px] uppercase tracking-[0.16em]"
        >
          {photoCount} Photographs
        </dd>
        <dt class="sr-only">Region</dt>
        <dd
          class="bg-secondary-fixed text-on-secondary-fixed px-3 py-1.5 font-sans text-[11px] uppercase tracking-[0.16em]"
        >
          Chester County, PA
        </dd>
        <dt class="sr-only">Last updated</dt>
        <dd
          class="px-3 py-1.5 font-sans text-[11px] uppercase tracking-[0.16em] text-on-surface-variant"
        >
          Updated {updated}
        </dd>
      </dl>
    </section>

    {/* ------------------------------------------------------------------ */}
    {/* § II. Selected photographs                                          */}
    {/* ------------------------------------------------------------------ */}
    <section
      id="selected-photographs"
      class="relative mx-auto max-w-7xl px-6 pb-24 md:px-10 md:pb-32"
    >
      <div class="grid gap-10 md:grid-cols-12 md:gap-16">
        <div class="md:col-span-4">
          <h2
            class="mt-3 font-display text-3xl font-light tracking-[-0.01em] md:text-[2.5rem]"
          >
            Selected <span class="italic">photographs.</span>
          </h2>
          <p
            class="mt-4 max-w-xs text-sm leading-relaxed text-on-surface-variant"
          >
            Catalogued by date and plate, each photograph preserves the
            photographer&rsquo;s notes alongside the image.
          </p>
        </div>

        <SelectedPhotos client:only="react" locations={locations} />
      </div>
    </section>
  </main>
  {/* ------------------------------------------------------------------ */}
  {/* Colophon                                                            */}
  {/* ------------------------------------------------------------------ */}
  <footer class="mx-auto max-w-7xl px-6 pb-16 md:px-10">
    <div
      class="flex flex-wrap items-baseline justify-between gap-2 bg-[linear-gradient(to_right,transparent,color-mix(in_srgb,var(--outline-variant)_30%,transparent),transparent)] bg-size-[100%_1px] bg-no-repeat bg-top pt-10 font-sans text-[11px] uppercase tracking-[0.28em] text-on-surface-variant"
    >
      <span>Tredyffrin Aerial Photos</span>
    </div>
  </footer>
</Layout>
