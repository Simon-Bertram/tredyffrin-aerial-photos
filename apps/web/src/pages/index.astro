---
import Layout from "../layouts/Layout.astro";
import { TredyffrinMap } from "../components/tredyffrinMap";
import { locations } from "../lib/locations";
---

<Layout title="tredyffrin-aerial-photos">
  <main id="main-content">
    <div class="container mx-auto px-4 py-2">
      <h1 class="text-2xl font-bold p-8">Tredyffrin Aerial Photos</h1>
      <p>This is a collection of aerial photos of Tredyffrin Township, PA.</p>
      <div class="p-12">
        <TredyffrinMap client:load locations={locations} />
      </div>
      <ul>
        <li>
          <a href="/photos/1">Photo 1</a>
        </li>
        <li>
          <a href="/photos/2">Photo 2</a>
        </li>
      </ul>
    </div>
  </main>
</Layout>
