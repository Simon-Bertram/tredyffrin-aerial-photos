---
import type { LocationPhoto } from "@/lib/locations";

interface Props {
  photo: LocationPhoto;
}

const { photo } = Astro.props;
---

<article class="card border border-border bg-card shadow-sm">
  <figure class="aspect-4/3 w-full overflow-hidden">
    <img
      src={photo.src}
      alt={photo.alt}
      class="h-full w-full object-cover"
      loading="lazy"
      decoding="async"
    />
  </figure>
  <div class="card-body">
    {photo.title ? <h3 class="card-title">{photo.title}</h3> : null}
    {
      photo.caption ? (
        <p class="text-sm text-muted-foreground">{photo.caption}</p>
      ) : null
    }
    {
      photo.photographer ? (
        <p class="text-sm text-muted-foreground">
          <span class="italic">Photographer:</span> {photo.photographer}
        </p>
      ) : null
    }
    {
      photo.photoDate ? (
        <p class="text-sm text-muted-foreground">
          <span class="italic">Year:</span> {photo.photoDate}
        </p>
      ) : null
    }
    {
      photo.direction ? (
        <p class="text-sm text-muted-foreground">
          <span class="italic">Direction:</span> {photo.direction}
        </p>
      ) : null
    }
    {
      photo.references ? (
        <p class="text-sm text-muted-foreground">
          <span class="italic">References:</span> {photo.references}
        </p>
      ) : null
    }
    {
      photo.comments ? (
        <p class="text-sm text-muted-foreground">
          <span class="italic">Comments:</span> {photo.comments}
        </p>
      ) : null
    }
  </div>
</article>
