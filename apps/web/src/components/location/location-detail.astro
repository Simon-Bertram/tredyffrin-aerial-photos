---
import BackToMapLink from "@/components/location/back-to-map-link.astro";
import type { LocationRecord } from "@/lib/locations";
import { LocationPhotoGalleryLauncher } from "@/components/location/location-photo-gallery-launcher";

interface Props {
  location: LocationRecord;
}

const { location } = Astro.props;
const photoCount = location.photos.length;
---

<BackToMapLink />

{
  photoCount > 0 ? (
    <section>
      <h2 class="text-lg font-bold mb-8">Location Photos ({photoCount})</h2>
      <LocationPhotoGalleryLauncher client:load photos={location.photos} />
    </section>
  ) : (
    <section class="rounded-lg border bg-card p-6 text-sm text-muted-foreground">
      No photos are available for this location yet.
    </section>
  )
}
