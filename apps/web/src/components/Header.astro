---
const links = [{ to: "/about", label: "About" }];
---

<header
  class="relative bg-[color-mix(in_srgb,var(--secondary-container)_55%,var(--surface))] dark:bg-[color-mix(in_srgb,var(--secondary-fixed)_50%,var(--surface))]"
>
  <div
    class="mx-auto flex max-w-7xl items-baseline justify-between gap-6 px-6 pt-8 pb-6 md:px-10 md:pt-10"
  >
    <a href="/" class="group flex items-baseline gap-3">
      <span
        class="font-display text-xl font-light tracking-[-0.01em] md:text-[1.65rem]"
      >
        Tredyffrin<span
          class="text-on-surface-variant italic font-normal group-hover:text-primary transition-colors"
          >&thinsp;&middot;&thinsp;Aerial Archive</span
        >
      </span>
    </a>

    <nav
      class="flex items-baseline gap-6 text-[11px] uppercase tracking-[0.22em]"
    >
      {
        links.map((link) => (
          <a
            href={link.to}
            class="text-on-surface-variant hover:text-primary transition-colors"
          >
            {link.label}
          </a>
        ))
      }
    </nav>
  </div>
  {/* Tonal seam instead of a divider line. */}
  <div
    class="mx-auto h-px max-w-7xl bg-[linear-gradient(to_right,transparent,color-mix(in_srgb,var(--outline-variant)_58%,transparent),transparent)]"
  >
  </div>
</header>
