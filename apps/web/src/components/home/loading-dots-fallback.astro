---
interface Props {
	variant: 'map' | 'coverflow'
}

const { variant } = Astro.props
---

{
	variant === 'map' ? (
		<div class="bg-surface-container h-full w-full animate-pulse">
			<div class="flex h-full items-center justify-center">
				<div class="flex gap-1">
					<span class="bg-on-surface-variant/30 size-1.5 rounded-full" />
					<span class="bg-on-surface-variant/30 size-1.5 rounded-full" />
					<span class="bg-on-surface-variant/30 size-1.5 rounded-full" />
				</div>
			</div>
		</div>
	) : (
		<div class="bg-surface-container-low flex h-full min-h-[280px] w-full items-center justify-center border border-outline-variant/20">
			<div class="flex gap-1" aria-hidden="true">
				<span class="bg-on-surface-variant/30 size-1.5 rounded-full animate-pulse" />
				<span class="bg-on-surface-variant/30 size-1.5 rounded-full animate-pulse [animation-delay:150ms]" />
				<span class="bg-on-surface-variant/30 size-1.5 rounded-full animate-pulse [animation-delay:300ms]" />
			</div>
		</div>
	)
}
