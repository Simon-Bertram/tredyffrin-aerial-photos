{
  "name": "tredyffrin-aerial-photos",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^5",
      "@cloudflare/workers-types": "^4.20251213.0",
      "alchemy": "^0.93.6"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "test:web": "vitest run",
    "dev:web": "turbo -F web dev",
    "deploy": "turbo -F @tredyffrin-aerial-photos/infra deploy",
    "deploy:preflight": "turbo -F @tredyffrin-aerial-photos/infra preflight:cloudflare",
    "destroy": "turbo -F @tredyffrin-aerial-photos/infra destroy"
  },
  "dependencies": {
    "@fontsource-variable/newsreader": "^5.2.10",
    "@fontsource-variable/public-sans": "^5.2.7",
    "@tredyffrin-aerial-photos/env": "workspace:*",
    "dotenv": "^17.4.2",
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260501.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@tredyffrin-aerial-photos/config": "workspace:*",
    "jsdom": "^29.1.1",
    "turbo": "^2.9.7",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "packageManager": "bun@1.3.12"
}
