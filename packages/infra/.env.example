# Loaded by alchemy.run.ts together with ../../apps/web/.env
#
# Set PUBLIC_SERVER_URL to the canonical HTTPS URL of the deployed site before
# deploy (no trailing slash). This value is passed to the Worker as a binding
# and must match what users see in the browser.
PUBLIC_SERVER_URL=https://example.com

# Cloudflare (Alchemy / Wrangler). Use a valid Account API Token; a bad token
# yields HTTP 400 from `wrangler whoami`. Both files above load with
# override: true so values here win over a stale CLOUDFLARE_API_TOKEN in your
# shell. To use OAuth instead, omit this variable and run `wrangler login`.
# CLOUDFLARE_API_TOKEN=
